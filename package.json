{
  "name": "pcnse-150-preguntas",
  "version": "2.1.0",
  "description": "PCNSE 150 preguntas — Simulador gratuito con audio TTS en voz del autor (ES/EN). 150 preguntas con tips y explicaciones para el examen PCNSE de Palo Alto Networks. Voz clonada MiniMax (Jeff-Aporta).",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "python scripts/dev-server.py",
    "build": "node scripts/build.mjs",
    "build:tscheck": "tsc --noEmit -p tsconfig.json",
    "generate:audio": "node scripts/generate-audio.mjs --clips",
    "generate:audio:mono": "node scripts/generate-audio.mjs --mono",
    "batches:audio": "node scripts/regenerate-clips-batch.mjs",
    "consolidate:audio": "node scripts/consolidate-clips.mjs",
    "translate:en": "node scripts/translate-questions-en.mjs",
    "test": "node --test tests/*.test.mjs",
    "validate:audio": "powershell -ExecutionPolicy Bypass -File scripts/validate-audio.ps1"
  },
  "keywords": [
    "PCNSE",
    "Palo Alto Networks",
    "PCNSE-150-preguntas",
    "simulador",
    "firewall",
    "neon-glass",
    "typescript",
    "react",
    "mui",
    "minimax",
    "tts-voice-clone"
  ],
  "author": "Jeff-Aporta",
  "license": "MIT"
}